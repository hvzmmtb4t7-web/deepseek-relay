# Your DeepSeek API key (get it at https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Server port
PORT=3000

# Client API keys (comma-separated) — generate strong random strings
CLIENT_API_KEYS=sk-local-dev-key-change-me

# Pricing display (per 1M tokens)
PRICING_INPUT_PER_1M=0.17
PRICING_OUTPUT_PER_1M=0.35
